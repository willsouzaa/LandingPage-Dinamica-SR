      "example": "ESSÊNCIA CARLESSI"
    },
    "construtora": {
      "type": "text",
      "description": "Nome da construtora/incorporadora",
      "maxLength": 20,
      "example": "CARLESSI"
    },
    "headline": {
      "type": "text",
      "description": "Frase principal de impacto (parte normal, cor clara)",
      "maxLength": 35,
      "example": "Córrego Grande em sua forma"
    },
    "headlineHighlight": {
      "type": "text",
      "description": "Palavra de destaque em itálico e cor dourada",
      "maxLength": 20,
