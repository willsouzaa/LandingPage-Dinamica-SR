    },
    "card1Label": {
      "type": "text",
      "description": "Label do primeiro card",
      "maxLength": 18,
      "example": "Dormitórios"
    },
    "card2Valor": {
      "type": "text",
      "description": "Valor do segundo card",
      "maxLength": 14,
      "example": "37–160m²"
    },
    "card2Label": {
      "type": "text",
      "description": "Label do segundo card",
      "maxLength": 18,
      "example": "Área Privativa"
    },
    "card3Valor": {
      "type": "text",
      "description": "Valor do terceiro card",
      "maxLength": 14,
      "example": "Lazer completo"
