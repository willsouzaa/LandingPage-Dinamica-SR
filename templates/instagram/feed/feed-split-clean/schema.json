{
  "id": "feed-split-clean",
  "slots": {
    "nome": {
      "type": "text",
      "description": "Nome do empreendimento",
      "maxLength": 20,
      "example": "BRIO 778"
    },
    "construtora": {
      "type": "text",
      "description": "Nome da construtora/incorporadora",
      "maxLength": 20,
      "example": "D.LOHN"
    },
    "headline": {
      "type": "text",
      "description": "Início da headline (parte serifada normal)",
      "maxLength": 22,
      "example": "Viva o Estreito com"
    },
    "headlineHighlight": {
      "type": "text",
      "description": "Palavra final em itálico e cor primária",
      "maxLength": 15,
      "example": "Brio."
    },
    "badge1": {
      "type": "text",
      "description": "Badge de status",
      "maxLength": 18,
      "example": "LANÇAMENTO"
    },
    "localizacaoLinha1": {
      "type": "text",
      "description": "Primeira linha de localização",
      "maxLength": 22,
      "example": "Estreito"
    },
    "localizacaoLinha2": {
      "type": "text",
      "description": "Segunda linha de localização",
      "maxLength": 22,
      "example": "Florianópolis, SC"
    },
    "dado1Valor": {
      "type": "text",
      "description": "Valor do primeiro dado",
      "maxLength": 12,
      "example": "62–98m²"
    },
    "dado1Label": {
      "type": "text",
      "description": "Label do primeiro dado",
      "maxLength": 15,
      "example": "Área Privativa"
    },
    "dado2Valor": {
      "type": "text",
      "description": "Valor do segundo dado",
      "maxLength": 12,
      "example": "2 e 3 dorm."
    },
    "dado2Label": {
      "type": "text",
      "description": "Label do segundo dado",
      "maxLength": 15,
      "example": "Dormitórios"
    },
    "dado3Valor": {
      "type": "text",
      "description": "Valor do terceiro dado",
      "maxLength": 12,
      "example": "1–2 vagas"
    },
    "dado3Label": {
      "type": "text",
      "description": "Label do terceiro dado",
      "maxLength": 15,
      "example": "Garagem"
    },
    "cta": {
      "type": "text",
      "description": "Texto do CTA (sem seta, ela é adicionada automaticamente)",
      "maxLength": 30,
      "example": "Conheça o empreendimento"
    },
    "imagemPrincipalUrl": {
      "type": "image",
      "description": "Foto da fachada (recortada em arco/círculo no topo direito)",
      "recommended": "fachada"
    },
    "imagemSecundariaUrl": {
      "type": "image",
      "description": "Foto de lifestyle (pequena, sobreposta no canto inferior esquerdo)",
      "recommended": "lazer"
    },
    "corPrimaria": {
      "type": "color",
      "description": "Cor de destaque (headline highlight, badge, CTA)",
      "example": "#B85C3A"
    },
    "corFundo": {
      "type": "color",
      "description": "Cor de fundo creme",
      "example": "#F5F0E8"
    }
  }
}
